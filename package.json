{
  "name": "clawguard-shield",
  "version": "0.1.0",
  "description": "Lightweight JavaScript client for the ClawGuard Shield API — detect prompt injection in under 10ms",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node build.js",
    "test": "node --test test/shield.test.js",
    "test:coverage": "node --test --experimental-test-coverage test/shield.test.js",
    "lint": "echo 'no lint configured'",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "ai-security",
    "prompt-injection",
    "llm-security",
    "clawguard",
    "shield",
    "ai-agent",
    "security-scanner",
    "eu-ai-act"
  ],
  "author": "Joerg Michno <michno.jrg@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/joergmichno/clawguard-shield-js.git"
  },
  "homepage": "https://prompttools.co",
  "bugs": {
    "url": "https://github.com/joergmichno/clawguard-shield-js/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {}
}
